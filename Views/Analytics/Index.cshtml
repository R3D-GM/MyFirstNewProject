@model MyFirstNewProject.ViewModels.AnalyticsViewModel

@{
    ViewData["Title"] = "Customer Analytics";
}

<div class="container-fluid px-0">
    <!-- Page Header -->
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h1 class="display-6 fw-bold">
                <i class="bi bi-graph-up text-primary"></i> Customer Analytics
            </h1>
            <p class="text-muted">Business intelligence and customer insights</p>
        </div>
        <div>
            <span class="badge bg-primary rounded-pill fs-6 p-3">
                <i class="bi bi-database"></i> @Model.TotalCustomers records
            </span>
        </div>
    </div>

    <!-- KPI Cards -->
    <div class="row g-4 mb-4">
        <div class="col-md-3">
            <div class="card stats-card bg-primary text-white shadow-sm">
                <div class="card-body text-center">
                    <h6 class="card-title">Total Customers</h6>
                    <h2>@Model.TotalCustomers</h2>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card stats-card bg-success text-white shadow-sm">
                <div class="card-body text-center">
                    <h6 class="card-title">Active</h6>
                    <h2>@Model.ActiveCustomers</h2>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card stats-card bg-success text-white shadow-sm">
                <div class="card-body text-center">
                    <h6 class="card-title">Companies</h6>
                    <h2>@Model.TotalCompanies</h2>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card stats-card bg-info text-white shadow-sm">
                <div class="card-body text-center">
                    <h6 class="card-title">Persons</h6>
                    <h2>@Model.TotalPersons</h2>
                </div>
            </div>
        </div>
    </div>

    <!-- Charts -->
    <div class="row g-4 mb-4">
        <!-- Type Distribution -->
        <div class="col-md-6">
            <div class="card border-0">
                <div class="card-header">
                    <h5 class="mb-0"><i class="bi bi-pie-chart text-primary"></i> Customer Type Distribution</h5>
                </div>
                <div class="card-body">
                    <div style="height: 300px;">
                        <canvas id="typeChart"></canvas>
                    </div>
                </div>
            </div>
        </div>

        <!-- Status Distribution -->
        <div class="col-md-6">
            <div class="card border-0">
                <div class="card-header">
                    <h5 class="mb-0"><i class="bi bi-circle text-success"></i> Status Distribution</h5>
                </div>
                <div class="card-body">
                    <div style="height: 300px;">
                        <canvas id="statusChart"></canvas>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Business Type Distribution -->
    <div class="row g-4 mb-4">
        <div class="col-12">
            <div class="card border-0">
                <div class="card-header">
                    <h5 class="mb-0"><i class="bi bi-bar-chart text-primary"></i> Business Type Distribution</h5>
                </div>
                <div class="card-body">
                    <div style="height: 300px;">
                        <canvas id="businessTypeChart"></canvas>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Quick Stats -->
    <div class="row g-4">
        <div class="col-12">
            <div class="card border-0">
                <div class="card-header">
                    <h5 class="mb-0"><i class="bi bi-clipboard-data text-primary"></i> Quick Statistics</h5>
                </div>
                <div class="card-body">
                    <div class="row text-center">
                        <div class="col-md-3">
                            <h6 class="text-muted">Total Customers</h6>
                            <h3 class="fw-bold">@Model.TotalCustomers</h3>
                        </div>
                        <div class="col-md-3">
                            <h6 class="text-muted">Active Rate</h6>
                            <h3 class="fw-bold text-success">@(Model.TotalCustomers > 0 ? Math.Round((double)Model.ActiveCustomers / Model.TotalCustomers * 100) : 0)%</h3>
                        </div>
                        <div class="col-md-3">
                            <h6 class="text-muted">Companies</h6>
                            <h3 class="fw-bold text-success">@Model.TotalCompanies</h3>
                        </div>
                        <div class="col-md-3">
                            <h6 class="text-muted">Persons</h6>
                            <h3 class="fw-bold text-info">@Model.TotalPersons</h3>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script>
        document.addEventListener('DOMContentLoaded', function() {

            // 1. PIE CHART - Customer Type
            var ctx1 = document.getElementById('typeChart').getContext('2d');
            new Chart(ctx1, {
                type: 'pie',
                data: {
                    labels: ['Companies', 'Persons'],
                    datasets: [{
                        data: [@Model.TotalCompanies, @Model.TotalPersons],
                        backgroundColor: ['#64B5F6', '#8EB69B'],
                        borderColor: ['#1976D2', '#6B9E7A'],
                        borderWidth: 2
                    }]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    plugins: {
                        legend: {
                            position: 'bottom',
                            labels: { color: '#94a3b8' }
                        }
                    }
                }
            });

            // 2. DOUGHNUT CHART - Status
            var ctx2 = document.getElementById('statusChart').getContext('2d');
            new Chart(ctx2, {
                type: 'doughnut',
                data: {
                    labels: ['Active', 'Inactive'],
                    datasets: [{
                        data: [@Model.ActiveCustomers, @Model.InactiveCustomers],
                        backgroundColor: ['#66BB6A', '#EF5350'],
                        borderColor: ['#2E7D32', '#C62828'],
                        borderWidth: 2
                    }]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    plugins: {
                        legend: {
                            position: 'bottom',
                            labels: { color: '#94a3b8' }
                        }
                    }
                }
            });

            // 3. BAR CHART - Business Type
            var businessTypes = @Html.Raw(Json.Serialize(Model.BusinessTypeDistribution.Select(b => b.Type)));
            var businessCounts = @Html.Raw(Json.Serialize(Model.BusinessTypeDistribution.Select(b => b.Count)));
            
            var ctx3 = document.getElementById('businessTypeChart').getContext('2d');
            new Chart(ctx3, {
                type: 'bar',
                data: {
                    labels: businessTypes,
                    datasets: [{
                        label: 'Customers by Business Type',
                        data: businessCounts,
                        backgroundColor: [
                            '#235347', '#8EB69B', '#0B2B26',
                            '#235347', '#8EB69B', '#0B2B26'
                        ],
                        borderColor: '#1e293b',
                        borderWidth: 2,
                        borderRadius: 8
                    }]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    plugins: {
                        legend: {
                            display: false
                        }
                    },
                    scales: {
                        y: {
                            beginAtZero: true,
                            ticks: { color: '#94a3b8', stepSize: 1 },
                            grid: { color: '#1e293b' }
                        },
                        x: {
                            ticks: { color: '#94a3b8' },
                            grid: { display: false }
                        }
                    }
                }
            });
        });
    </script>
}

@section Styles {
    <style>
        .stats-card {
            border-radius: 15px;
            border: none;
            transition: transform 0.2s;
        }
        .stats-card:hover {
            transform: translateY(-5px);
            box-shadow: 0 8px 25px rgba(0,0,0,0.15);
        }
        .card {
            border-radius: 15px;
            border: none;
        }
        .card-header {
            border-radius: 15px 15px 0 0;
        }
        .bg-primary {
            background: linear-gradient(135deg, #8EB1D1, #A7C7E7) !important;
            color: #1C2B48 !important;
        }
        .bg-success {
            background: linear-gradient(135deg, #4A7C5E, #6B9E7A) !important;
        }
        .bg-info {
            background: linear-gradient(135deg, #A7C7E7, #8EB1D1) !important;
            color: #1C2B48 !important;
        }
    </style>
}