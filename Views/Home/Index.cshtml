@model List<MyFirstNewProject.Models.Consignee>

@{
    ViewData["Title"] = "Consignees";
    int currentPage = ViewBag.CurrentPage ?? 1;
    int totalPages = ViewBag.TotalPages ?? 1;
    int totalRecords = ViewBag.TotalRecords ?? 0;
    int pageSize = ViewBag.PageSize ?? 10;
    int startRecord = (currentPage - 1) * pageSize + 1;
    int endRecord = Math.Min(currentPage * pageSize, totalRecords);
    bool hasFilters = !string.IsNullOrEmpty(ViewBag.SearchTerm) ||
                      !string.IsNullOrEmpty(ViewBag.Type) ||
                      !string.IsNullOrEmpty(ViewBag.Status);

    // Windowed pagination: show up to 5 page numbers around current page
    int windowSize = 2;
    int startPage = Math.Max(1, currentPage - windowSize);
    int endPage = Math.Min(totalPages, currentPage + windowSize);
    // Adjust window if at edges
    if (endPage - startPage < windowSize * 2 && totalPages > windowSize * 2)
    {
        if (currentPage <= totalPages / 2)
        {
            endPage = Math.Min(totalPages, startPage + windowSize * 2);
        }
        else
        {
            startPage = Math.Max(1, endPage - windowSize * 2);
        }
    }
}

<div class="text-center mb-4">
    <h1 class="display-4">Consignees List</h1>
    <p class="text-muted">Data fetched from API</p>
</div>

@if (ViewBag.Error != null)
{
    <div class="alert alert-danger">
        @ViewBag.Error
    </div>
}

@if (Model != null && Model.Any())
{
    <!-- Filter Form -->
    <div class="card mb-4">
        <div class="card-header d-flex justify-content-between align-items-center">
            <h5 class="mb-0">
                <i class="bi bi-funnel"></i> Filters
            </h5>
            @if (hasFilters)
            {
                <a href="@Url.Action("Index")" class="btn btn-sm btn-outline-secondary">
                    &times; Clear Filters
                </a>
            }
        </div>
        <div class="card-body">
            <form method="get" asp-action="Index" class="row g-3">
                <div class="col-md-4">
                    <label for="searchTerm" class="form-label">Search</label>
                    <input type="text" class="form-control" id="searchTerm" name="searchTerm"
                           value="@ViewBag.SearchTerm" placeholder="Search by name or code...">
                </div>
                <div class="col-md-3">
                    <label for="type" class="form-label">Type</label>
                    <select class="form-select" id="type" name="type">
                        <option value="">All Types</option>
                        <option value="person" selected="@(ViewBag.Type == "person" ? "selected" : null)">Person</option>
                        <option value="company" selected="@(ViewBag.Type == "company" ? "selected" : null)">Company</option>
                    </select>
                </div>
                <div class="col-md-3">
                    <label for="status" class="form-label">Status</label>
                    <select class="form-select" id="status" name="status">
                        <option value="">All Statuses</option>
                        <option value="active" selected="@(ViewBag.Status == "active" ? "selected" : null)">Active</option>
                        <option value="inactive" selected="@(ViewBag.Status == "inactive" ? "selected" : null)">Inactive</option>
                    </select>
                </div>
                <div class="col-md-2 d-flex align-items-end">
                    <button type="submit" class="btn btn-primary w-100">
                        <i class="bi bi-search"></i> Apply
                    </button>
                </div>
            </form>
        </div>
    </div>

    <!-- Results Info & Page Size Selector -->
    <div class="d-flex justify-content-between align-items-center mb-3">
        <div class="alert alert-info mb-0 py-2 flex-grow-1 me-3">
            Showing <strong>@startRecord</strong> - <strong>@endRecord</strong> of <strong>@totalRecords</strong> records
        </div>
        <div class="d-flex align-items-center">
            <label for="pageSizeSelector" class="form-label me-2 mb-0 text-nowrap">Per page:</label>
            <select id="pageSizeSelector" class="form-select form-select-sm" style="width: auto;"
                    onchange="window.location.href = '@Url.Action("Index", new {
                        searchTerm = ViewBag.SearchTerm,
                        type = ViewBag.Type,
                        status = ViewBag.Status,
                        sortBy = ViewBag.SortBy,
                        sortDirection = ViewBag.SortDirection,
                        page = 1,
                        pageSize = "__PS__"
                    })'.replace('__PS__', this.value);">
                <option value="5" selected="@(pageSize == 5 ? "selected" : null)">5</option>
                <option value="10" selected="@(pageSize == 10 ? "selected" : null)">10</option>
                <option value="20" selected="@(pageSize == 20 ? "selected" : null)">20</option>
                <option value="50" selected="@(pageSize == 50 ? "selected" : null)">50</option>
                <option value="100" selected="@(pageSize == 100 ? "selected" : null)">100</option>
            </select>
        </div>
    </div>

    <!-- Data Table -->
    <div class="table-responsive">
        <table class="table table-striped table-bordered table-hover">
            <thead class="table-dark">
                <tr>
                    <th>
                        <a href="@Url.Action("Index", new {
                            searchTerm = ViewBag.SearchTerm,
                            type = ViewBag.Type,
                            status = ViewBag.Status,
                            sortBy = "id",
                            sortDirection = ViewBag.SortBy == "id" && ViewBag.SortDirection == "asc" ? "desc" : "asc",
                            page = 1,
                            pageSize = ViewBag.PageSize
                        })" class="text-decoration-none text-white">
                            ID
                            @if (ViewBag.SortBy == "id")
                            {
                                <span>@(ViewBag.SortDirection == "asc" ? " ▲" : " ▼")</span>
                            }
                        </a>
                    </th>
                    <th>
                        <a href="@Url.Action("Index", new {
                            searchTerm = ViewBag.SearchTerm,
                            type = ViewBag.Type,
                            status = ViewBag.Status,
                            sortBy = "code",
                            sortDirection = ViewBag.SortBy == "code" && ViewBag.SortDirection == "asc" ? "desc" : "asc",
                            page = 1,
                            pageSize = ViewBag.PageSize
                        })" class="text-decoration-none text-white">
                            Code
                            @if (ViewBag.SortBy == "code")
                            {
                                <span>@(ViewBag.SortDirection == "asc" ? " ▲" : " ▼")</span>
                            }
                        </a>
                    </th>
                    <th>
                        <a href="@Url.Action("Index", new {
                            searchTerm = ViewBag.SearchTerm,
                            type = ViewBag.Type,
                            status = ViewBag.Status,
                            sortBy = "name",
                            sortDirection = ViewBag.SortBy == "name" && ViewBag.SortDirection == "asc" ? "desc" : "asc",
                            page = 1,
                            pageSize = ViewBag.PageSize
                        })" class="text-decoration-none text-white">
                            Name
                            @if (ViewBag.SortBy == "name")
                            {
                                <span>@(ViewBag.SortDirection == "asc" ? " ▲" : " ▼")</span>
                            }
                        </a>
                    </th>
                    <th>Type</th>
                    <th>Status</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td>@item.Id</td>
                        <td>@item.Code</td>
                        <td>@item.FirstName @item.SecondName @item.ThirdName</td>
                        <td>
                            <span class="badge @(item.IsPerson ? "bg-primary" : "bg-secondary")">
                                @(item.IsPerson ? "Person" : "Company")
                            </span>
                        </td>
                        <td>
                            <span class="badge @(item.IsActive ? "bg-success" : "bg-danger")">
                                @(item.IsActive ? "Active" : "Inactive")
                            </span>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    <!-- Windowed Pagination -->
    @if (totalPages > 1)
    {
        <nav aria-label="Page navigation">
            <ul class="pagination justify-content-center">
                <!-- First -->
                <li class="page-item @(currentPage == 1 ? "disabled" : "")">
                    <a class="page-link" href="@Url.Action("Index", new {
                        searchTerm = ViewBag.SearchTerm,
                        type = ViewBag.Type,
                        status = ViewBag.Status,
                        sortBy = ViewBag.SortBy,
                        sortDirection = ViewBag.SortDirection,
                        page = 1,
                        pageSize = ViewBag.PageSize
                    })" aria-label="First">
                        <span aria-hidden="true">&laquo;&laquo;</span>
                    </a>
                </li>
                <!-- Previous -->
                <li class="page-item @(currentPage == 1 ? "disabled" : "")">
                    <a class="page-link" href="@Url.Action("Index", new {
                        searchTerm = ViewBag.SearchTerm,
                        type = ViewBag.Type,
                        status = ViewBag.Status,
                        sortBy = ViewBag.SortBy,
                        sortDirection = ViewBag.SortDirection,
                        page = currentPage - 1,
                        pageSize = ViewBag.PageSize
                    })" aria-label="Previous">
                        <span aria-hidden="true">&laquo;</span>
                    </a>
                </li>

                <!-- Ellipsis + Page Numbers -->
                @if (startPage > 1)
                {
                    <li class="page-item disabled">
                        <span class="page-link">...</span>
                    </li>
                }
                @for (int i = startPage; i <= endPage; i++)
                {
                    <li class="page-item @(i == currentPage ? "active" : "")">
                        <a class="page-link" href="@Url.Action("Index", new {
                            searchTerm = ViewBag.SearchTerm,
                            type = ViewBag.Type,
                            status = ViewBag.Status,
                            sortBy = ViewBag.SortBy,
                            sortDirection = ViewBag.SortDirection,
                            page = i,
                            pageSize = ViewBag.PageSize
                        })">@i</a>
                    </li>
                }
                @if (endPage < totalPages)
                {
                    <li class="page-item disabled">
                        <span class="page-link">...</span>
                    </li>
                }

                <!-- Next -->
                <li class="page-item @(currentPage == totalPages ? "disabled" : "")">
                    <a class="page-link" href="@Url.Action("Index", new {
                        searchTerm = ViewBag.SearchTerm,
                        type = ViewBag.Type,
                        status = ViewBag.Status,
                        sortBy = ViewBag.SortBy,
                        sortDirection = ViewBag.SortDirection,
                        page = currentPage + 1,
                        pageSize = ViewBag.PageSize
                    })" aria-label="Next">
                        <span aria-hidden="true">&raquo;</span>
                    </a>
                </li>
                <!-- Last -->
                <li class="page-item @(currentPage == totalPages ? "disabled" : "")">
                    <a class="page-link" href="@Url.Action("Index", new {
                        searchTerm = ViewBag.SearchTerm,
                        type = ViewBag.Type,
                        status = ViewBag.Status,
                        sortBy = ViewBag.SortBy,
                        sortDirection = ViewBag.SortDirection,
                        page = totalPages,
                        pageSize = ViewBag.PageSize
                    })" aria-label="Last">
                        <span aria-hidden="true">&raquo;&raquo;</span>
                    </a>
                </li>
            </ul>
        </nav>
    }
}
else if (ViewBag.Error == null)
{
    <div class="alert alert-warning">
        <i class="bi bi-exclamation-triangle"></i> No data found. Please check the API connection.
    </div>
}