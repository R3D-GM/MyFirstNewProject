@model List<MyFirstNewProject.Models.Consignee>

@{
    ViewData["Title"] = "Customer List";
    var searchTerm = ViewBag.SearchTerm as string;
    var sortBy = ViewBag.SortBy as string;
    var sortDirection = ViewBag.SortDirection as string;
    var currentPage = ViewBag.CurrentPage ?? 1;
    var totalPages = ViewBag.TotalPages ?? 1;
    var totalRecords = ViewBag.TotalRecords ?? 0;
}

<div class="container-fluid px-0">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h1 class="display-6 fw-bold">
                <i class="bi bi-people text-primary"></i> Customers
            </h1>
            <p class="text-muted">Manage and view all customer records</p>
        </div>
        <div>
            <span class="badge bg-primary rounded-pill fs-6 p-3">
                <i class="bi bi-database"></i> @totalRecords records
            </span>
        </div>
    </div>

    @if (ViewBag.Error != null)
    {
        <div class="alert alert-danger alert-dismissible fade show shadow-sm">
            <i class="bi bi-exclamation-triangle-fill"></i> @ViewBag.Error
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <!-- Loading Spinner -->
    <div id="loadingSpinner" class="text-center py-5" style="display: none;">
        <div class="spinner-border text-primary" role="status" style="width: 3rem; height: 3rem;">
            <span class="visually-hidden">Loading...</span>
        </div>
        <p class="mt-2 text-muted">Loading customers...</p>
    </div>

    <!-- ============================================ -->
    <!-- SEARCH, FILTER, SORT SECTION               -->
    <!-- ============================================ -->
    <div class="card border-0 mb-4">
        <div class="card-body">
            <form method="get" class="row g-3">
                <!-- Search -->
                <div class="col-md-3">
                    <label class="form-label"><i class="bi bi-search"></i> Search</label>
                    <div class="input-group">
                        <input type="text" name="searchTerm" class="form-control" 
                               placeholder="Search by name or code..." value="@searchTerm" />
                        <button type="submit" class="btn btn-primary">
                            <i class="bi bi-search"></i>
                        </button>
                        @if (!string.IsNullOrEmpty(searchTerm))
                        {
                            <a href="@Url.Action("Index")" class="btn btn-outline-secondary">
                                <i class="bi bi-x-circle"></i>
                            </a>
                        }
                    </div>
                </div>

                <!-- Filter by Type -->
                <div class="col-md-2">
                    <label class="form-label"><i class="bi bi-filter"></i> Type</label>
                    <select name="type" class="form-select" onchange="this.form.submit()">
                        <option value="">All Types</option>
                        <option value="person" selected="@(ViewBag.Type == "person")">Person</option>
                        <option value="company" selected="@(ViewBag.Type == "company")">Company</option>
                    </select>
                </div>

                <!-- Filter by Status -->
                <div class="col-md-2">
                    <label class="form-label"><i class="bi bi-filter"></i> Status</label>
                    <select name="status" class="form-select" onchange="this.form.submit()">
                        <option value="">All Status</option>
                        <option value="active" selected="@(ViewBag.Status == "active")">Active</option>
                        <option value="inactive" selected="@(ViewBag.Status == "inactive")">Inactive</option>
                    </select>
                </div>

                <!-- Sort By -->
                <div class="col-md-2">
                    <label class="form-label"><i class="bi bi-arrow-up-down"></i> Sort By</label>
                    <select name="sortBy" class="form-select" onchange="this.form.submit()">
                        <option value="">Default</option>
                        <option value="id" selected="@(sortBy == "id")">ID</option>
                        <option value="code" selected="@(sortBy == "code")">Code</option>
                        <option value="name" selected="@(sortBy == "name")">Name</option>
                    </select>
                </div>

                <!-- Order -->
                <div class="col-md-2">
                    <label class="form-label"><i class="bi bi-arrow-down-up"></i> Order</label>
                    <select name="sortDirection" class="form-select" onchange="this.form.submit()">
                        <option value="asc" selected="@(sortDirection == "asc")">Ascending</option>
                        <option value="desc" selected="@(sortDirection == "desc")">Descending</option>
                    </select>
                </div>

                <!-- Clear Button -->
                <div class="col-md-1 d-flex align-items-end">
                    <a href="@Url.Action("Index")" class="btn btn-secondary w-100">
                        <i class="bi bi-arrow-counterclockwise"></i>
                    </a>
                </div>
            </form>
        </div>
    </div>

    <!-- ============================================ -->
    <!-- DATA TABLE                                  -->
    <!-- ============================================ -->
    <div class="card border-0">
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover mb-0">
                    <thead>
                        <tr>
                            <th>#</th>
                            <th>Code</th>
                            <th>Name</th>
                            <th>Type</th>
                            <th>Business</th>
                            <th>Status</th>
                            <th class="text-center">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (Model != null && Model.Any())
                        {
                            var counter = (currentPage - 1) * 10 + 1;
                            foreach (var item in Model)
                            {
                                <tr>
                                    <td>@counter</td>
                                    <td><span class="badge bg-secondary">@item.Code</span></td>
                                    <td>
                                        <strong>@item.FirstName</strong>
                                        @if (!string.IsNullOrEmpty(item.SecondName))
                                        {
                                            <span>@item.SecondName</span>
                                        }
                                    </td>
                                    <td>
                                    <span class="badge @(item.IsPerson ? "bg-info" : "bg-success")">
                                        @(item.IsPerson ? "👤 Person" : "🏢 Company")
                                        </span>
                                    </td>
                                    <td>@(item.BusinessType ?? "N/A")</td>
                                    <td>
                                        <span class="badge @(item.IsActive ? "bg-success" : "bg-danger")">
                                            @(item.IsActive ? "Active" : "Inactive")
                                        </span>
                                    </td>
                                    <td class="text-center">
                                        <a href="@Url.Action("Details", new { id = item.Id })" 
                                           class="btn btn-sm btn-outline-primary">
                                            <i class="bi bi-eye"></i> View
                                        </a>
                                    </td>
                                </tr>
                                counter++;
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="7" class="text-center py-5">
                                    <i class="bi bi-inbox display-1 d-block text-muted"></i>
                                    <h4 class="text-muted">No records found</h4>
                                    <p class="text-muted">Try adjusting your search or filters</p>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    <!-- ============================================ -->
    <!-- PAGINATION                                  -->
    <!-- ============================================ -->
    <!-- ============================================ -->
<!-- PAGINATION                                  -->
<!-- ============================================ -->
@if (totalPages > 1)
{
    <div class="mt-4">
        <nav aria-label="Page navigation">
            <ul class="pagination justify-content-center">
                <!-- Previous Button -->
                <li class="page-item @(currentPage <= 1 ? "disabled" : "")">
                    <a class="page-link" 
                       href="@Url.Action("Index", new { 
                           searchTerm = searchTerm, 
                           sortBy = sortBy, 
                           sortDirection = sortDirection,
                           type = ViewBag.Type,
                           status = ViewBag.Status,
                           page = currentPage - 1 
                       })">
                        <i class="bi bi-chevron-left"></i> Prev
                    </a>
                </li>

                <!-- Page Numbers (Only show 5 at a time) -->
                @{
                    int startPage = Math.Max(1, currentPage - 2);
                    int endPage = Math.Min(totalPages, currentPage + 2);
                    
                    // If near the beginning, show first 5
                    if (currentPage <= 3)
                    {
                        startPage = 1;
                        endPage = Math.Min(5, totalPages);
                    }
                    // If near the end, show last 5
                    else if (currentPage >= totalPages - 2)
                    {
                        startPage = Math.Max(1, totalPages - 4);
                        endPage = totalPages;
                    }
                    
                    // Show first page if not included
                    if (startPage > 1)
                    {
                        <li class="page-item">
                            <a class="page-link" 
                               href="@Url.Action("Index", new { 
                                   searchTerm = searchTerm, 
                                   sortBy = sortBy, 
                                   sortDirection = sortDirection,
                                   type = ViewBag.Type,
                                   status = ViewBag.Status,
                                   page = 1 
                               })">1</a>
                        </li>
                        if (startPage > 2)
                        {
                            <li class="page-item disabled"><span class="page-link">…</span></li>
                        }
                    }

                    @for (int i = startPage; i <= endPage; i++)
                    {
                        <li class="page-item @(i == currentPage ? "active" : "")">
                            <a class="page-link" 
                               href="@Url.Action("Index", new { 
                                   searchTerm = searchTerm, 
                                   sortBy = sortBy, 
                                   sortDirection = sortDirection,
                                   type = ViewBag.Type,
                                   status = ViewBag.Status,
                                   page = i 
                               })">@i</a>
                        </li>
                    }

                    // Show last page if not included
                    if (endPage < totalPages)
                    {
                        if (endPage < totalPages - 1)
                        {
                            <li class="page-item disabled"><span class="page-link">…</span></li>
                        }
                        <li class="page-item">
                            <a class="page-link" 
                               href="@Url.Action("Index", new { 
                                   searchTerm = searchTerm, 
                                   sortBy = sortBy, 
                                   sortDirection = sortDirection,
                                   type = ViewBag.Type,
                                   status = ViewBag.Status,
                                   page = totalPages 
                               })">@totalPages</a>
                        </li>
                    }
                }

                <!-- Next Button -->
                <li class="page-item @(currentPage >= totalPages ? "disabled" : "")">
                    <a class="page-link" 
                       href="@Url.Action("Index", new { 
                           searchTerm = searchTerm, 
                           sortBy = sortBy, 
                           sortDirection = sortDirection,
                           type = ViewBag.Type,
                           status = ViewBag.Status,
                           page = currentPage + 1 
                       })">
                        Next <i class="bi bi-chevron-right"></i>
                    </a>
                </li>
            </ul>
        </nav>
        <div class="text-center text-muted">
            Showing page @currentPage of @totalPages
            (@((currentPage - 1) * 10 + 1) - @Math.Min(currentPage * 10, totalRecords) of @totalRecords records)
        </div>
    </div>
}
    <!-- ============================================ -->
    <!-- STATS CARDS                                 -->
    <!-- ============================================ -->
    <div class="row g-4 mt-2">
        <div class="col-md-3">
            <div class="card stats-card border-0">
                <div class="card-body text-center">
                    <h6 class="text-muted">Total</h6>
                    <h2 class="fw-bold">@totalRecords</h2>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card stats-card border-0">
                <div class="card-body text-center">
                    <h6 class="text-muted">Active</h6>
                    <h2 class="fw-bold text-success">@(Model?.Count(c => c.IsActive) ?? 0)</h2>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card stats-card border-0">
                <div class="card-body text-center">
                                    <h6 class="text-muted">Companies</h6>
                                    <h2 class="fw-bold text-success" style="color: #8EB69B !important;">@(Model?.Count(c => !c.IsPerson) ?? 0)</h2>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card stats-card border-0">
                <div class="card-body text-center">
                    <h6 class="text-muted">Persons</h6>
                    <h2 class="fw-bold text-info">@(Model?.Count(c => c.IsPerson) ?? 0)</h2>
                </div>
            </div>
        </div>
    </div>
</div>

@section Styles {
    <style>
        .stats-card {
            background: linear-gradient(145deg, #111827, #0d1420) !important;
            border: 1px solid rgba(59, 130, 246, 0.15) !important;
            border-radius: 16px !important;
            transition: all 0.3s ease;
        }
        .stats-card:hover {
            transform: translateY(-4px);
            border-color: #3b82f6 !important;
            box-shadow: 0 8px 30px rgba(59, 130, 246, 0.15);
        }
        .btn-outline-secondary {
            color: #94a3b8 !important;
            border-color: rgba(148, 163, 184, 0.2) !important;
        }
        .btn-outline-secondary:hover {
            background: rgba(148, 163, 184, 0.1) !important;
            color: white !important;
        }
        .table > :not(caption) > * > * {
            background-color: transparent !important;
        }
        .table-hover > tbody > tr:hover {
            background-color: rgba(59, 130, 246, 0.05) !important;
        }
    </style>
}

@section Scripts {
    <script>
        // Show loading spinner when any action starts
        document.querySelectorAll('a, button, select').forEach(el => {
            el.addEventListener('click', function() {
                if (this.tagName !== 'A' || this.href) {
                    document.getElementById('loadingSpinner').style.display = 'block';
                }
            });
        });
    </script>
}