@model List<MyFirstNewProject.Models.Consignee>

@{
    ViewData["Title"] = "Customer List";
    var searchTerm = ViewBag.SearchTerm as string;
    var sortBy = ViewBag.SortBy as string;
    var sortDirection = ViewBag.SortDirection as string;
    var currentPage = ViewBag.CurrentPage ?? 1;
    var totalPages = ViewBag.TotalPages ?? 1;
    var totalRecords = ViewBag.TotalRecords ?? 0;
}

<div class="container mt-4">
    <h1 class="mb-4">
        <i class="bi bi-people-fill text-primary"></i> Customer List
        <span class="badge bg-primary rounded-pill fs-6 ms-2">@totalRecords records</span>
    </h1>

    @if (ViewBag.Error != null)
    {
        <div class="alert alert-danger alert-dismissible fade show shadow-sm">
            <i class="bi bi-exclamation-triangle-fill"></i> @ViewBag.Error
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <!-- Loading Spinner -->
    <div id="loadingSpinner" class="text-center py-5" style="display: none;">
        <div class="spinner-border text-primary" role="status" style="width: 3rem; height: 3rem;">
            <span class="visually-hidden">Loading...</span>
        </div>
        <p class="mt-2">Loading customers...</p>
    </div>

    <!-- Search and Filter Section -->
    <div class="card shadow-sm mb-4">
        <div class="card-body">
            <form method="get" class="row g-3">
                <div class="col-md-4">
                    <label class="form-label fw-bold">
                        <i class="bi bi-search"></i> Search
                    </label>
                    <div class="input-group">
                        <input type="text" name="searchTerm" class="form-control" 
                               placeholder="Search by name or code..." value="@searchTerm" />
                        <button type="submit" class="btn btn-primary">
                            <i class="bi bi-search"></i>
                        </button>
                        @if (!string.IsNullOrEmpty(searchTerm))
                        {
                            <a href="@Url.Action("Index")" class="btn btn-outline-secondary">
                                <i class="bi bi-x-circle"></i>
                            </a>
                        }
                    </div>
                </div>

                <div class="col-md-2">
                    <label class="form-label fw-bold">
                        <i class="bi bi-filter"></i> Type
                    </label>
                    <select name="type" class="form-select" onchange="this.form.submit()">
                        <option value="">All Types</option>
                        <option value="person" selected="@(ViewBag.Type == "person")">Person</option>
                        <option value="company" selected="@(ViewBag.Type == "company")">Company</option>
                    </select>
                </div>

                <div class="col-md-2">
                    <label class="form-label fw-bold">
                        <i class="bi bi-filter"></i> Status
                    </label>
                    <select name="status" class="form-select" onchange="this.form.submit()">
                        <option value="">All Status</option>
                        <option value="active" selected="@(ViewBag.Status == "active")">Active</option>
                        <option value="inactive" selected="@(ViewBag.Status == "inactive")">Inactive</option>
                    </select>
                </div>

                <div class="col-md-2">
                    <label class="form-label fw-bold">
                        <i class="bi bi-arrow-up-down"></i> Sort By
                    </label>
                    <select name="sortBy" class="form-select" onchange="this.form.submit()">
                        <option value="">Default</option>
                        <option value="id" selected="@(sortBy == "id")">ID</option>
                        <option value="code" selected="@(sortBy == "code")">Code</option>
                        <option value="name" selected="@(sortBy == "name")">Name</option>
                    </select>
                </div>

                <div class="col-md-2">
                    <label class="form-label fw-bold">
                        <i class="bi bi-arrow-down-up"></i> Order
                    </label>
                    <select name="sortDirection" class="form-select" onchange="this.form.submit()">
                        <option value="asc" selected="@(sortDirection == "asc")">Ascending</option>
                        <option value="desc" selected="@(sortDirection == "desc")">Descending</option>
                    </select>
                </div>
            </form>
        </div>
    </div>

    <!-- Data Table -->
    <div class="card shadow-sm">
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-striped table-hover mb-0">
                    <thead class="table-dark">
                        <tr>
                            <th>#</th>
                            <th>Code</th>
                            <th>Name</th>
                            <th>Type</th>
                            <th>Business</th>
                            <th>Status</th>
                            <th class="text-center">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (Model != null && Model.Any())
                        {
                            var counter = (currentPage - 1) * 10 + 1;
                            foreach (var item in Model)
                            {
                                <tr>
                                    <td>@counter</td>
                                    <td><span class="badge bg-secondary">@item.Code</span></td>
                                    <td>
                                        <strong>@item.FirstName</strong>
                                        @if (!string.IsNullOrEmpty(item.SecondName))
                                        {
                                            <span>@item.SecondName</span>
                                        }
                                    </td>
                                    <td>
                                        <span class="badge @(item.IsPerson ? "bg-info" : "bg-warning")">
                                            @(item.IsPerson ? "👤 Person" : "🏢 Company")
                                        </span>
                                    </td>
                                    <td>@(item.BusinessType ?? "N/A")</td>
                                    <td>
                                        <span class="badge @(item.IsActive ? "bg-success" : "bg-danger")">
                                            @(item.IsActive ? "✅ Active" : "❌ Inactive")
                                        </span>
                                    </td>
                                    <td class="text-center">
                                        <a href="@Url.Action("Details", new { id = item.Id })" 
                                           class="btn btn-sm btn-outline-primary">
                                            <i class="bi bi-eye"></i> View
                                        </a>
                                    </td>
                                </tr>
                                counter++;
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="7" class="text-center py-5">
                                    <i class="bi bi-inbox display-1 d-block text-muted"></i>
                                    <h4 class="text-muted">No records found</h4>
                                    <p class="text-muted">Try adjusting your search or filters</p>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    <!-- Pagination -->
    @if (totalPages > 1)
    {
        <div class="mt-4">
            <nav aria-label="Page navigation">
                <ul class="pagination justify-content-center">
                    <li class="page-item @(currentPage <= 1 ? "disabled" : "")">
                        <a class="page-link" 
                           href="@Url.Action("Index", new { 
                               searchTerm = searchTerm, 
                               sortBy = sortBy, 
                               sortDirection = sortDirection, 
                               type = ViewBag.Type,
                               status = ViewBag.Status,
                               page = currentPage - 1 
                           })">
                            <i class="bi bi-chevron-left"></i> Previous
                        </a>
                    </li>

                    @for (int i = 1; i <= totalPages; i++)
                    {
                        <li class="page-item @(i == currentPage ? "active" : "")">
                            <a class="page-link" 
                               href="@Url.Action("Index", new { 
                                   searchTerm = searchTerm, 
                                   sortBy = sortBy, 
                                   sortDirection = sortDirection,
                                   type = ViewBag.Type,
                                   status = ViewBag.Status,
                                   page = i 
                               })">@i</a>
                        </li>
                    }

                    <li class="page-item @(currentPage >= totalPages ? "disabled" : "")">
                        <a class="page-link" 
                           href="@Url.Action("Index", new { 
                               searchTerm = searchTerm, 
                               sortBy = sortBy, 
                               sortDirection = sortDirection,
                               type = ViewBag.Type,
                               status = ViewBag.Status,
                               page = currentPage + 1 
                           })">
                            Next <i class="bi bi-chevron-right"></i>
                        </a>
                    </li>
                </ul>
            </nav>
            <div class="text-center text-muted">
                Showing page @currentPage of @totalPages
                (@((currentPage - 1) * 10 + 1) - @Math.Min(currentPage * 10, totalRecords) of @totalRecords records)
            </div>
        </div>
    }

    <!-- Stats Cards with Cerulean Theme -->
    <div class="row mt-4">
        <div class="col-md-3">
            <div class="card stats-card bg-primary text-dark shadow-sm">
                <div class="card-body text-center">
                    <h5 class="card-title"><i class="bi bi-people"></i> Total</h5>
                    <h2>@totalRecords</h2>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card stats-card bg-success text-white shadow-sm">
                <div class="card-body text-center">
                    <h5 class="card-title"><i class="bi bi-check-circle"></i> Active</h5>
                    <h2>@(Model?.Count(c => c.IsActive) ?? 0)</h2>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card stats-card bg-warning text-dark shadow-sm">
                <div class="card-body text-center">
                    <h5 class="card-title"><i class="bi bi-building"></i> Companies</h5>
                    <h2>@(Model?.Count(c => !c.IsPerson) ?? 0)</h2>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card stats-card bg-info text-dark shadow-sm">
                <div class="card-body text-center">
                    <h5 class="card-title"><i class="bi bi-person"></i> Persons</h5>
                    <h2>@(Model?.Count(c => c.IsPerson) ?? 0)</h2>
                </div>
            </div>
        </div>
    </div>
</div>

@section Styles {
    <style>
        .card {
            border-radius: 10px;
            border: none;
        }
        .table th {
            font-weight: 600;
        }
        .pagination .page-link {
            border-radius: 5px;
            margin: 0 2px;
        }
        .badge {
            font-size: 0.85em;
            padding: 5px 10px;
        }
        .stats-card {
            transition: transform 0.2s;
        }
        .stats-card:hover {
            transform: translateY(-5px);
            box-shadow: 0 8px 25px rgba(28, 43, 72, 0.2);
        }
        
        /* Cerulean Theme Colors */
        .bg-primary {
            background: linear-gradient(135deg, #8EB1D1, #A7C7E7) !important;
            color: #1C2B48 !important;
        }
        .bg-success {
            background: linear-gradient(135deg, #4A7C5E, #6B9E7A) !important;
        }
        .bg-warning {
            background: linear-gradient(135deg, #C4D8E5, #E8ECEF) !important;
            color: #1C2B48 !important;
        }
        .bg-info {
            background: linear-gradient(135deg, #A7C7E7, #8EB1D1) !important;
            color: #1C2B48 !important;
        }
        
        /* Badges */
        .badge.bg-secondary {
            background: #C4D8E5 !important;
            color: #1C2B48 !important;
        }
        .badge.bg-success {
            background: #5D8A6E !important;
            color: white !important;
        }
        .badge.bg-danger {
            background: #C47B7A !important;
            color: white !important;
        }
        .badge.bg-warning {
            background: #C4D8E5 !important;
            color: #1C2B48 !important;
        }
        .badge.bg-info {
            background: #A7C7E7 !important;
            color: #1C2B48 !important;
        }
        
        /* Buttons */
        .btn-primary {
            background: linear-gradient(135deg, #8EB1D1, #A7C7E7);
            border: none;
            color: #1C2B48;
        }
        .btn-primary:hover {
            background: linear-gradient(135deg, #A7C7E7, #8EB1D1);
            transform: translateY(-2px);
            box-shadow: 0 4px 12px rgba(28, 43, 72, 0.3);
            color: #1C2B48;
        }
        .btn-outline-primary {
            color: #8EB1D1;
            border-color: #8EB1D1;
        }
        .btn-outline-primary:hover {
            background: #8EB1D1;
            color: #1C2B48;
            border-color: #8EB1D1;
        }
        .btn-outline-secondary {
            color: #C4D8E5;
            border-color: #C4D8E5;
        }
        .btn-outline-secondary:hover {
            background: #C4D8E5;
            color: #1C2B48;
            border-color: #C4D8E5;
        }
        
        /* Table */
        .table-dark {
            background: #1C2B48 !important;
        }
        .table-striped > tbody > tr:nth-of-type(odd) {
            background-color: rgba(142, 177, 209, 0.08);
        }
        .table-hover > tbody > tr:hover {
            background-color: rgba(167, 199, 231, 0.15);
        }
        
        /* Pagination */
        .pagination .page-link {
            color: #1C2B48;
            border-color: #C4D8E5;
            border-radius: 5px;
            margin: 0 2px;
        }
        .pagination .page-link:hover {
            background: #A7C7E7;
            border-color: #8EB1D1;
        }
        .pagination .active .page-link {
            background: #8EB1D1;
            border-color: #8EB1D1;
            color: #1C2B48;
        }
        
        /* Text Colors */
        .text-primary {
            color: #8EB1D1 !important;
        }
        .text-muted {
            color: #1C2B48 !important;
            opacity: 0.6;
        }
        
        /* Spinner */
        .spinner-border.text-primary {
            color: #8EB1D1 !important;
        }
    </style>
}

@section Scripts {
    <script>
        // Show loading spinner when any action starts
        document.querySelectorAll('a, button, select').forEach(el => {
            el.addEventListener('click', function() {
                if (this.tagName !== 'A' || this.href) {
                    document.getElementById('loadingSpinner').style.display = 'block';
                }
            });
        });

        // Auto-hide flash messages after 5 seconds
        setTimeout(function() {
            const alerts = document.querySelectorAll('.alert.alert-dismissible');
            alerts.forEach(alert => {
                alert.style.transition = 'opacity 1s';
                alert.style.opacity = '0';
                setTimeout(() => alert.remove(), 1000);
            });
        }, 5000);
    </script>
}