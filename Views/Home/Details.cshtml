@model MyFirstNewProject.Models.Consignee

@{
    ViewData["Title"] = "Customer Details";
}

<div class="container-fluid px-0">
    <a href="@Url.Action("Index")" class="btn btn-outline-secondary mb-4">
        <i class="bi bi-arrow-left"></i> Back to List
    </a>

    <div class="card border-0">
        <div class="card-header">
            <h2 class="mb-0">
                <i class="bi bi-person-badge text-primary"></i> Customer Details
            </h2>
        </div>
        <div class="card-body">
            @if (ViewBag.Error != null)
            {
                <div class="alert alert-danger">@ViewBag.Error</div>
            }

            @if (Model != null)
            {
                <div class="row">
                    <div class="col-md-6">
                        <div class="mb-4">
                            <label class="text-muted small text-uppercase fw-semibold">ID</label>
                            <p class="fs-4 fw-bold">@Model.Id</p>
                        </div>
                        <div class="mb-4">
                            <label class="text-muted small text-uppercase fw-semibold">Code</label>
                            <p><span class="badge bg-secondary">@Model.Code</span></p>
                        </div>
                        <div class="mb-4">
                            <label class="text-muted small text-uppercase fw-semibold">Full Name</label>
                            <p class="fs-5">
                                @Model.FirstName 
                                @if (!string.IsNullOrEmpty(Model.SecondName))
                                {
                                    <span>@Model.SecondName</span>
                                }
                                @if (!string.IsNullOrEmpty(Model.ThirdName))
                                {
                                    <span>@Model.ThirdName</span>
                                }
                            </p>
                        </div>
                        <div class="mb-4">
                            <label class="text-muted small text-uppercase fw-semibold">Type</label>
                            <p>
                                <span class="badge @(Model.IsPerson ? "bg-info" : "bg-success") fs-6">
                                    @(Model.IsPerson ? "👤 Person" : "🏢 Company")
                                </span>
                            </p>
                        </div>
                        <div class="mb-4">
                            <label class="text-muted small text-uppercase fw-semibold">Business Type</label>
                            <p>@(Model.BusinessType ?? "N/A")</p>
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="mb-4">
                            <label class="text-muted small text-uppercase fw-semibold">Status</label>
                            <p>
                                <span class="badge @(Model.IsActive ? "bg-success" : "bg-danger") fs-6">
                                    @(Model.IsActive ? "✅ Active" : "❌ Inactive")
                                </span>
                            </p>
                        </div>
                        <div class="mb-4">
                            <label class="text-muted small text-uppercase fw-semibold">TIN</label>
                            <p>@(Model.Tin ?? "N/A")</p>
                        </div>
                        <div class="mb-4">
                            <label class="text-muted small text-uppercase fw-semibold">Gender</label>
                            <p>@(Model.Gender ?? "N/A")</p>
                        </div>
                        <div class="mb-4">
                            <label class="text-muted small text-uppercase fw-semibold">Created On</label>
                            <p>@Model.CreatedOn.ToString("yyyy-MM-dd HH:mm")</p>
                        </div>
                        <div class="mb-4">
                            <label class="text-muted small text-uppercase fw-semibold">Last Modified</label>
                            <p>@Model.LastModified.ToString("yyyy-MM-dd HH:mm")</p>
                        </div>
                    </div>
                </div>

                <hr class="border-secondary" />

                <div class="d-flex justify-content-between align-items-center">
                    <a href="@Url.Action("Index")" class="btn btn-primary">
                        <i class="bi bi-arrow-left"></i> Back to List
                    </a>
                    <span class="text-muted">ID: @Model.Id</span>
                </div>
            }
            else
            {
                <div class="alert alert-warning">Customer not found</div>
                <a href="@Url.Action("Index")" class="btn btn-primary">Back to List</a>
            }
        </div>
    </div>
</div>

@section Styles {
    <style>
        .card {
            background: linear-gradient(145deg, #111827, #0d1420) !important;
            border: 1px solid rgba(59, 130, 246, 0.15) !important;
            border-radius: 16px !important;
        }
        .card-header {
            border-bottom: 1px solid rgba(59, 130, 246, 0.1) !important;
            background: transparent !important;
        }
        .badge {
            padding: 8px 16px;
        }
        .badge.fs-6 {
            font-size: 1rem;
        }
        hr {
            border-color: rgba(59, 130, 246, 0.1) !important;
        }
        .text-muted {
            color: #94a3b8 !important;
        }
        .btn-primary {
            background: linear-gradient(135deg, #60a5fa, #a78bfa) !important;
            border: none !important;
        }
        .btn-primary:hover {
            transform: translateY(-2px);
            box-shadow: 0 8px 30px rgba(96, 165, 250, 0.4);
        }
        .btn-outline-secondary {
            color: #94a3b8 !important;
            border-color: rgba(148, 163, 184, 0.2) !important;
        }
        .btn-outline-secondary:hover {
            background: rgba(148, 163, 184, 0.1) !important;
            color: white !important;
        }
    </style>
}