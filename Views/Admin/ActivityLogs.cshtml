@model List<MyFirstNewProject.Models.ActivityLog>

@{
    ViewData["Title"] = "Activity Logs";
}

<div class="container-fluid px-0">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h1 class="display-6 fw-bold">
                <i class="bi bi-clock-history text-primary"></i> Activity Logs
            </h1>
            <p class="text-muted">Audit trail of all system actions</p>
        </div>
        <a asp-action="Index" class="btn btn-outline-secondary">
            <i class="bi bi-arrow-left"></i> Back to Admin
        </a>
    </div>

    <div class="card border-0">
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover mb-0">
                    <thead>
                        <tr>
                            <th>Time</th>
                            <th>User</th>
                            <th>Action</th>
                            <th>Details</th>
                            <th>Severity</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (Model != null && Model.Any())
                        {
                            foreach (var log in Model)
                            {
                                <tr>
                                    <td>@log.Timestamp.ToString("yyyy-MM-dd HH:mm:ss")</td>
                                    <td>@log.UserEmail</td>
                                    <td>@log.Action</td>
                                    <td>@log.Details</td>
                                    <td>
                                        <span class="badge @(log.Severity == "Warning" ? "bg-warning" : log.Severity == "Error" ? "bg-danger" : "bg-info")">
                                            @log.Severity
                                        </span>
                                    </td>
                                </tr>
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="5" class="text-center py-5">
                                    <i class="bi bi-inbox display-1 d-block text-muted"></i>
                                    <h4 class="text-muted">No activity logs found</h4>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>