@model List<Microsoft.AspNetCore.Identity.IdentityRole>

@{
    ViewData["Title"] = "Role Management";
}

<div class="container-fluid px-0">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h1 class="display-6 fw-bold">
                <i class="bi bi-shield-lock text-primary"></i> Role Management
            </h1>
            <p class="text-muted">Manage user roles</p>
        </div>
        <a asp-action="Index" class="btn btn-outline-secondary">
            <i class="bi bi-arrow-left"></i> Back to Admin
        </a>
    </div>

    <div class="card border-0">
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover mb-0">
                    <thead>
                        <tr>
                            <th>#</th>
                            <th>Role Name</th>
                            <th>Users with this Role</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (Model != null && Model.Any())
                        {
                            var counter = 1;
                            foreach (var role in Model)
                            {
                                <tr>
                                    <td>@counter</td>
                                    <td>
                                        <span class="badge @(role.Name == "Admin" ? "bg-danger" : role.Name == "Manager" ? "bg-warning" : "bg-info")">
                                            @role.Name
                                        </span>
                                    </td>
                                    <td>
                                        <span class="text-muted">N/A</span>
                                    </td>
                                </tr>
                                counter++;
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="3" class="text-center py-5">
                                    <i class="bi bi-inbox display-1 d-block text-muted"></i>
                                    <h4 class="text-muted">No roles found</h4>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

@section Styles {
    <style>
        .badge.bg-warning {
            color: #0a0e1a !important;
        }
        .badge.bg-info {
            color: #0a0e1a !important;
        }
    </style>
}